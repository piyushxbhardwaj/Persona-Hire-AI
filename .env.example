# ==========================================
# PersonaHire AI - Environment Configuration
# ==========================================

# 1. LLM & Embeddings (OpenAI)
# Required for RAG generation and vector database indexing
OPENAI_API_KEY=your_openai_api_key_here

# 2. GitHub Integration (Optional)
# If provided, dynamic repository fetching is enabled.
# If omitted or rate-limited, the system falls back to data/github_mock.json.
GITHUB_TOKEN=your_github_personal_access_token_here

# 3. Google Calendar API Integration (Optional)
# Provide the Service Account JSON credentials string directly.
# If omitted, the system falls back to a robust stateful mock calendar file.
GOOGLE_CALENDAR_CREDENTIALS_JSON=your_google_service_account_credentials_json_string_here
# Alternative: Path to credentials file
# GOOGLE_APPLICATION_CREDENTIALS=path/to/service_account.json
# Calendar ID to schedule events on (defaults to 'primary')
GOOGLE_CALENDAR_ID=primary

# 4. Voice Agent Integration (Vapi)
# Optional webhook protection secret to verify inbound calls
VAPI_SECRET=your_vapi_verification_secret_here

# 5. Application Settings
PORT=8000
HOST=0.0.0.0
ENV=development
